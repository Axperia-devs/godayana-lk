{
  "projects": [
    {
      "name": "godayana-backend",
      "services": [
        {
          "name": "auth-service",
          "rootDirectory": "backend/services/auth-service",
          "buildCommand": "../../mvnw clean package -DskipTests",
          "startCommand": "java -jar -Dspring.profiles.active=railway target/*.jar",
          "healthcheckPath": "/actuator/health",
          "domains": ["auth.godayana.up.railway.app"]
        },
        {
          "name": "otp-service",
          "rootDirectory": "backend/services/otp-service",
          "buildCommand": "../../mvnw clean package -DskipTests",
          "startCommand": "java -jar -Dspring.profiles.active=railway target/*.jar",
          "healthcheckPath": "/actuator/health"
        },
        {
          "name": "user-service",
          "rootDirectory": "backend/services/user-service",
          "buildCommand": "../../mvnw clean package -DskipTests",
          "startCommand": "java -jar -Dspring.profiles.active=railway target/*.jar",
          "healthcheckPath": "/actuator/health"
        },
        {
          "name": "api-gateway",
          "rootDirectory": "backend/services/api-gateway",
          "buildCommand": "../../mvnw clean package -DskipTests",
          "startCommand": "java -jar -Dspring.profiles.active=railway target/*.jar",
          "healthcheckPath": "/actuator/health",
          "domains": ["api.godayana.up.railway.app"]
        }
      ]
    }
  ]
}