# Database Passwords (REQUIRED - change these!)
AUTH_DB_PASSWORD=ChangeMe123!
USER_DB_PASSWORD=ChangeMe456!
OTP_DB_PASSWORD=ChangeMe789!

# Docker Hub (REQUIRED)
DOCKER_USERNAME=your_dockerhub_username

# JWT Secret (REQUIRED - generate with: openssl rand -base64 64)
JWT_SECRET=your-super-secret-jwt-key-please-change-this-to-something-very-long-and-random

# Frontend API URL (for Railway deployment)
NEXT_PUBLIC_API_URL=https://your-project.up.railway.app

# Image tag (optional - defaults to 'latest')
IMAGE_TAG=latest